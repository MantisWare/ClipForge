# Database
DATABASE_URL="postgresql://clipforge:clipforge@localhost:5432/clipforge?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Web dev server (scan 4000–4999 by default; port 3000 is never used)
CLIPFORGE_WEB_PORT=4000
CLIPFORGE_WEB_PORT_MAX=4999

# Auth.js (AUTH_URL is set automatically at dev start to match the chosen port)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:4000"

# Google OAuth (optional — enables Google sign-in + future YouTube API)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend magic link (production sign-in)
AUTH_RESEND_KEY=""
EMAIL_FROM="ClipForge <onboarding@resend.dev>"

# Object storage (MinIO local dev)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="clipforge"
S3_SECRET_KEY="clipforge_secret"
S3_BUCKET="clipforge-media"
S3_PUBLIC_URL="http://localhost:9000"

# Clip candidate generation (Phase 4)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Optional: Azure / local OpenAI-compatible endpoint (Phase 10 affiliate discovery)
OPENAI_BASE_URL=""

# Optional Amazon Product Advertising API (Phase 10 — ASIN product URLs)
AMAZON_PAAPI_ACCESS_KEY=""
AMAZON_PAAPI_SECRET_KEY=""
AMAZON_PAAPI_REGION="us-east-1"
AMAZON_PAAPI_HOST="webservices.amazon.com"

# Optional eBay Browse API (Phase 11 — ASIN-level eBay matches)
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""
AUTO_GENERATE_CLIPS="false"

# YouTube Data API (Phase 2+)
YOUTUBE_API_KEY=""

# Source import (Phase 2 — apps/worker)
MAX_SOURCE_BYTES="2147483648"
IMPORT_TEMP_DIR="/tmp/clipforge"
YTDLP_PATH="yt-dlp"

# Transcription (Phase 3 — worker-ai + apps/worker)
WORKER_AI_URL="http://localhost:8002"
WHISPER_MODEL="base"
WHISPER_DEVICE="cpu"
AUTO_TRANSCRIBE="true"

# Publishing (Phase 6)
TOKEN_ENCRYPTION_KEY=""
YOUTUBE_OAUTH_REDIRECT_URI="http://localhost:4000/api/accounts/callback/youtube"

# Phase 8 — optional OSS limits (unset = unlimited)
MAX_SOURCES_PER_WORKSPACE=""
MAX_RENDERS_PER_DAY=""
MAX_BATCH_CLIPS="20"
BATCH_RENDER_CONCURRENCY="2"
ADMIN_USER_IDS=""

# Worker URLs (Phase 2+)
WORKER_VIDEO_URL="http://localhost:8001"

# Phase 9 — monetization overlays (set to "false" to disable overlay APIs/UI)
CLIPFORGE_OVERLAYS_ENABLED="true"
