{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "YOUTUBE_API_KEY",
    "GOOGLE_API_KEY",
    "YOUTUBE_DATA_API_KEY",
    "YTDLP_PATH",
    "AUTH_SECRET",
    "AUTH_URL",
    "PORT",
    "YOUTUBE_OAUTH_REDIRECT_URI",
    "DATABASE_URL",
    "REDIS_URL",
    "CLIPFORGE_DOCKER",
    "S3_ENDPOINT",
    "S3_PUBLIC_URL",
    "S3_REGION",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "OPENAI_API_KEY",
    "ADMIN_USER_IDS"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:seed": {
      "cache": false
    }
  }
}