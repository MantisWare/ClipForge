generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth.js tables ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Workspace ---

enum WorkspacePlan {
  free
  creator
  agency
  enterprise
}

model Workspace {
  id        String        @id @default(cuid())
  name      String
  ownerId   String
  plan      WorkspacePlan @default(free)
  renderWebhookUrl String? @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  owner              User                 @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members            WorkspaceMember[]
  sourceVideos       SourceVideo[]
  renderedClips      RenderedClip[]
  connectedAccounts  ConnectedAccount[]
  publishJobs        PublishJob[]
  jobs               Job[]
  brandKits          BrandKit[]
  captionStyles      CaptionStylePreset[]
  scheduledPublishes ScheduledPublish[]
  dailyStats         WorkspaceDailyStats[]
  overlayTemplates   OverlayTemplate[]
  productLinks       ProductLink[]
  overlaySettings    WorkspaceOverlaySettings?

  @@index([ownerId])
}

enum WorkspaceRole {
  owner
  admin
  editor
  viewer
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(editor)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// --- Source video ---

enum SourceType {
  youtube
  vimeo
  direct_url
  upload
}

enum SourceStatus {
  pending
  importing
  imported
  transcribing
  analyzing
  ready
  failed
}

enum RightsStatus {
  owned
  licensed
  permission_required
  unknown
}

model SourceVideo {
  id               String       @id @default(cuid())
  workspaceId      String
  sourceType       SourceType
  sourceUrl        String
  sourcePlatformId String?
  title            String?
  description      String?      @db.Text
  thumbnailUrl     String?
  durationSeconds  Float?
  width            Int?
  height           Int?
  fps              Float?
  language         String?
  storageKey       String?
  status           SourceStatus @default(pending)
  rightsStatus     RightsStatus @default(unknown)
  rightsConfirmed  Boolean      @default(false)
  rightsConfirmedAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transcriptSegments TranscriptSegment[]
  clipCandidates     ClipCandidate[]
  jobs               Job[]

  @@index([workspaceId])
  @@index([status])
}

model TranscriptSegment {
  id            String   @id @default(cuid())
  sourceVideoId String
  startMs       Int
  endMs         Int
  text          String   @db.Text
  confidence    Float?
  speakerLabel  String?
  createdAt     DateTime @default(now())

  sourceVideo SourceVideo      @relation(fields: [sourceVideoId], references: [id], onDelete: Cascade)
  words       TranscriptWord[]

  @@index([sourceVideoId])
}

model TranscriptWord {
  id        String @id @default(cuid())
  segmentId String
  word      String
  startMs   Int
  endMs     Int
  confidence Float?

  segment TranscriptSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([segmentId])
}

// --- Clip candidates ---

enum ClipStatus {
  candidate
  approved
  rejected
  rendered
  published
}

model ClipCandidate {
  id                String     @id @default(cuid())
  sourceVideoId     String
  startMs           Int
  endMs             Int
  durationSeconds   Float
  transcriptExcerpt String     @db.Text
  hookScore         Float      @default(0)
  viralityScore     Float      @default(0)
  clarityScore      Float      @default(0)
  standaloneScore   Float      @default(0)
  platformFitScore  Float      @default(0)
  overallScore      Float      @default(0)
  reasonSelected    String     @db.Text
  suggestedHook     String?
  suggestedTitle    String?
  suggestedCaption  String?    @db.Text
  suggestedHashtags String[]   @default([])
  status            ClipStatus @default(candidate)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  sourceVideo   SourceVideo    @relation(fields: [sourceVideoId], references: [id], onDelete: Cascade)
  renderedClips RenderedClip[]
  clipOverlays  ClipOverlay[]
  overlayRevisions ClipOverlayRevision[]

  @@index([sourceVideoId])
  @@index([status])
}

enum RenderVariant {
  clean
  monetized
}

enum RenderStatus {
  queued
  rendering
  ready
  failed
}

model RenderedClip {
  id              String       @id @default(cuid())
  clipCandidateId String
  workspaceId     String
  outputUrl       String?
  storageKey      String?
  cleanStorageKey     String?
  overlaysManifestKey String?
  thumbnailUrl    String?
  width           Int          @default(1080)
  height          Int          @default(1920)
  durationSeconds Float?
  renderPreset    String       @default("vertical_1080x1920")
  captionStyleId  String?
  brandKitId      String?
  renderVariant   RenderVariant @default(clean)
  experimentGroup String?
  status          RenderStatus @default(queued)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  clipCandidate  ClipCandidate         @relation(fields: [clipCandidateId], references: [id], onDelete: Cascade)
  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  captionStyle   CaptionStylePreset?   @relation(fields: [captionStyleId], references: [id], onDelete: SetNull)
  brandKit       BrandKit?             @relation(fields: [brandKitId], references: [id], onDelete: SetNull)
  publishJobs    PublishJob[]
  scheduledPublishes ScheduledPublish[]
  overlayLinkSlugs OverlayLinkSlug[]

  @@index([workspaceId])
  @@index([clipCandidateId])
  @@index([captionStyleId])
  @@index([brandKitId])
}

// --- Brand kits & caption presets (Phase 8) ---

model BrandKit {
  id               String   @id @default(cuid())
  workspaceId      String
  name             String
  isDefault        Boolean  @default(false)
  logoStorageKey   String?
  primaryColor     String   @default("#FFFFFF")
  secondaryColor   String?
  fontFamily       String   @default("Inter")
  hookFontSize     Int      @default(48)
  overlayDefaults  Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  captionStyles CaptionStylePreset[]
  renderedClips RenderedClip[]

  @@index([workspaceId])
}

model CaptionStylePreset {
  id          String   @id @default(cuid())
  workspaceId String
  brandKitId  String?
  name        String
  presetKey   String
  assTemplate Json     @default("{}")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandKit      BrandKit?      @relation(fields: [brandKitId], references: [id], onDelete: SetNull)
  renderedClips RenderedClip[]

  @@index([workspaceId])
  @@index([brandKitId])
}

enum ScheduledPublishStatus {
  scheduled
  published
  cancelled
  failed
}

model ScheduledPublish {
  id                 String                 @id @default(cuid())
  workspaceId        String
  renderedClipId     String
  connectedAccountId String?
  platform           Platform
  title              String?
  caption            String?                @db.Text
  hashtags           String[]               @default([])
  visibility         PublishVisibility      @default(public)
  scheduledFor       DateTime
  status             ScheduledPublishStatus @default(scheduled)
  publishJobId       String?
  errorMessage       String?                @db.Text
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  renderedClip   RenderedClip   @relation(fields: [renderedClipId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([scheduledFor])
  @@index([status])
}

model WorkspaceDailyStats {
  workspaceId       String
  date              DateTime @db.Date
  sourcesImported   Int      @default(0)
  clipsGenerated    Int      @default(0)
  clipsApproved     Int      @default(0)
  clipsRendered     Int      @default(0)
  publishAttempts   Int      @default(0)
  publishSuccess    Int      @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, date])
}

// --- Phase 9: Monetization overlays ---

enum OverlayType {
  end_slate
  product_pin
  affiliate_bar
  sponsor_segment
  promo_code
  qr_card
  image
}

enum OverlayCompliance {
  none
  affiliate
  sponsored
  ad
}

enum OverlayEventType {
  impression
  click
}

model WorkspaceOverlaySettings {
  workspaceId              String   @id
  defaultDisclosureText    String?  @db.Text
  defaultLocale            String   @default("en-US")
  urlAllowlist             String[] @default([])
  requireDisclosureOnExport Boolean @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model OverlayTemplate {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  overlayType OverlayType
  config      Json        @default("{}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clipOverlays ClipOverlay[]

  @@index([workspaceId])
}

model ProductLink {
  id               String   @id @default(cuid())
  workspaceId      String
  title            String
  url              String
  imageStorageKey  String?
  imageUrl         String?
  priceLabel       String?
  affiliateNetwork String?
  disclosureText   String?  @db.Text
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clipOverlays   ClipOverlay[]
  overlayLinkSlugs OverlayLinkSlug[]

  @@index([workspaceId])
}

model ClipOverlay {
  id              String            @id @default(cuid())
  clipCandidateId String
  overlayType     OverlayType
  templateId      String?
  productLinkId   String?
  startMs         Int
  endMs           Int
  position        Json              @default("{}")
  style           Json              @default("{}")
  compliance      OverlayCompliance @default(none)
  sortOrder       Int               @default(0)
  isDraft         Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  clipCandidate ClipCandidate    @relation(fields: [clipCandidateId], references: [id], onDelete: Cascade)
  template      OverlayTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  productLink   ProductLink?     @relation(fields: [productLinkId], references: [id], onDelete: SetNull)
  linkSlugs     OverlayLinkSlug[]

  @@index([clipCandidateId])
}

model ClipOverlayRevision {
  id              String   @id @default(cuid())
  clipCandidateId String
  snapshot        Json
  createdAt       DateTime @default(now())

  clipCandidate ClipCandidate @relation(fields: [clipCandidateId], references: [id], onDelete: Cascade)

  @@index([clipCandidateId])
}

model OverlayLinkSlug {
  id              String   @id @default(cuid())
  slug            String   @unique
  workspaceId     String
  productLinkId   String?
  renderedClipId  String?
  clipOverlayId   String?
  targetUrl       String
  createdAt       DateTime @default(now())

  productLink  ProductLink?  @relation(fields: [productLinkId], references: [id], onDelete: SetNull)
  renderedClip RenderedClip? @relation(fields: [renderedClipId], references: [id], onDelete: SetNull)
  clipOverlay  ClipOverlay?  @relation(fields: [clipOverlayId], references: [id], onDelete: SetNull)
  events       OverlayEvent[]

  @@index([workspaceId])
}

model OverlayEvent {
  id        String           @id @default(cuid())
  slugId    String
  type      OverlayEventType
  createdAt DateTime         @default(now())

  slug OverlayLinkSlug @relation(fields: [slugId], references: [id], onDelete: Cascade)

  @@index([slugId])
  @@index([createdAt])
}

// --- Connected accounts ---

enum Platform {
  youtube
  tiktok
  instagram
}

enum ConnectedAccountStatus {
  connected
  expired
  revoked
  requires_review
}

model ConnectedAccount {
  id                    String                 @id @default(cuid())
  workspaceId           String
  platform              Platform
  accountName           String
  externalAccountId     String
  accessTokenEncrypted  String                 @db.Text
  refreshTokenEncrypted String?                @db.Text
  tokenExpiresAt        DateTime?
  scopes                String[]               @default([])
  status                ConnectedAccountStatus @default(connected)
  publishCapability     String?                // DIRECT_POST_READY | PRIVATE_ONLY | REQUIRES_AUDIT
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishJobs        PublishJob[]
  scheduledPublishes ScheduledPublish[]

  @@index([workspaceId])
  @@unique([workspaceId, platform, externalAccountId])
}

// --- Publishing ---

enum PublishVisibility {
  public
  private
  unlisted
  draft
}

enum PublishJobStatus {
  draft
  queued
  publishing
  processing
  published
  failed
  requires_manual_action
}

model PublishJob {
  id                 String            @id @default(cuid())
  renderedClipId     String
  workspaceId        String
  platform           Platform
  connectedAccountId String?
  title              String?
  caption            String?           @db.Text
  hashtags           String[]          @default([])
  visibility         PublishVisibility @default(public)
  scheduledFor       DateTime?
  status             PublishJobStatus  @default(draft)
  externalPostId     String?
  externalUrl        String?
  errorMessage       String?           @db.Text
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  renderedClip     RenderedClip      @relation(fields: [renderedClipId], references: [id], onDelete: Cascade)
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
}

// --- Job queue audit ---

enum JobType {
  source_validate
  source_import
  source_extract_metadata
  media_extract_audio
  media_transcribe
  media_detect_scenes
  ai_score_clips
  ai_generate_metadata
  render_clip
  publish_youtube
  publish_tiktok
  publish_instagram
  batch_render
  publish_scheduled
  analytics_rollup
  render_apply_overlays
  ai_suggest_overlays
  overlay_validate_urls
}

enum JobStatus {
  queued
  running
  completed
  failed
  cancelled
  retrying
}

model Job {
  id            String    @id @default(cuid())
  workspaceId   String
  sourceVideoId String?
  type          JobType
  status        JobStatus @default(queued)
  payload       Json      @default("{}")
  result        Json?
  errorMessage  String?   @db.Text
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  bullJobId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceVideo SourceVideo? @relation(fields: [sourceVideoId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@index([type])
}
